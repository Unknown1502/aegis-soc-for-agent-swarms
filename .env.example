# ============================================================================
# AEGIS - environment configuration template
# ----------------------------------------------------------------------------
# Copy to .env and fill values. Never commit .env. Every Microsoft integration
# is gated by these variables and degrades safely (with an explicit log line)
# when its credentials are absent.
# ============================================================================

# --- Runtime ----------------------------------------------------------------
AEGIS_ENV=development                  # development | staging | production
AEGIS_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
AEGIS_API_HOST=127.0.0.1
AEGIS_API_PORT=8088
AEGIS_DASHBOARD_ORIGIN=http://localhost:5173

# --- Model backend ----------------------------------------------------------
# AEGIS chooses, in order: Azure OpenAI (Foundry) -> OpenAI -> deterministic offline mock.
# Configure the highest-fidelity backend you have available.

# Azure OpenAI / Azure AI Foundry  (preferred for hackathon scoring)
AZURE_OPENAI_ENDPOINT=                 # https://<your-foundry-project>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini    # deployment name in Foundry
AZURE_OPENAI_API_VERSION=2024-10-21

# Vanilla OpenAI (fallback for local dev before Azure is provisioned)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Azure AI Foundry project (tracing target) ------------------------------
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=     # https://<region>.api.azureml.ms/.../projects/<name>
AZURE_AI_FOUNDRY_CONNECTION_STRING=    # Foundry-issued APP INSIGHTS connection string
AZURE_SUBSCRIPTION_ID=/subscriptions/ea7eeab2-9427-41be-b367-a88246184544/resourceGroups/aegis-rg
AZURE_RESOURCE_GROUP=
AZURE_TENANT_ID=

# --- Azure AI Content Safety / Prompt Shields -------------------------------
AZURE_CONTENT_SAFETY_ENDPOINT=         # https://<resource>.cognitiveservices.azure.com
AZURE_CONTENT_SAFETY_KEY=

# --- Microsoft Entra Agent ID -----------------------------------------------
# OAuth2 / OIDC token verification for inter-agent messages.
ENTRA_TENANT_ID=2f52c65f-0f8a-4fcf-b54f-856d78bffc78
ENTRA_CLIENT_ID=                       # app registration for AEGIS guard
ENTRA_AGENT_AUDIENCE=api://aegis-agents
ENTRA_JWKS_URI=                        # https://login.microsoftonline.com/<tenant>/discovery/v2.0/keys
ENTRA_ISSUER=                          # https://login.microsoftonline.com/<tenant>/v2.0
# One app registration per victim agent -> genuinely live RS256 tokens.
# Single-line JSON; leave blank to keep the safe dev-mock identity path.
ENTRA_AGENT_CREDENTIALS=               # {"victim.orchestrator":{"client_id":"..","client_secret":".."}, ...}
AEGIS_FORCE_ENTRA_MOCK=false           # true = force dev-mock even if creds present (demo escape hatch)

# --- Defender for Cloud (AI Threat Protection) ------------------------------
# Either workspace polling (LogAnalytics) or direct alerts API.
AZURE_LOG_ANALYTICS_WORKSPACE_ID=
DEFENDER_ALERTS_RESOURCE_ID=

# --- Azure Monitor / Application Insights -----------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- AEGIS analyst dashboard auth (demo-only) -------------------------------
AEGIS_DEMO_USERNAME=demo
AEGIS_DEMO_PASSWORD=change-me-before-public-demo
AEGIS_JWT_SECRET=development-only-secret-do-not-ship

# --- Feature flags ----------------------------------------------------------
AEGIS_ENABLE_DEFENDER_INGEST=false
AEGIS_ENABLE_AZURE_MONITOR=false
AEGIS_ENABLE_FOUNDRY_TRACING=false
AEGIS_FORCE_OFFLINE_MOCK=false         # true = deterministic mock for CI / no-network demos
